# =============================================================================
# Server-side Azure credentials (Express API — never expose to the browser)
# Used for live OneDrive Excel data without visitor Microsoft sign-in.
# =============================================================================
AZURE_TENANT_ID=YOUR_TENANT_ID
AZURE_CLIENT_ID=YOUR_CLIENT_ID_FROM_AZURE
AZURE_CLIENT_SECRET=YOUR_CLIENT_SECRET

# OneDrive owner account (your work/school account that holds the workbook)
AZURE_DRIVE_USER_EMAIL=you@yourcompany.com
# AZURE_DRIVE_USER_ID=00000000-0000-0000-0000-000000000000

EXCEL_FILE_ID=YOUR_EXCEL_FILE_ITEM_ID
EXCEL_SHEET_NAME=Sheet1
PORT=3001

# =============================================================================
# Frontend (Vite) — optional; catalog MSAL sign-in only
# =============================================================================
VITE_AZURE_CLIENT_ID=YOUR_CLIENT_ID_FROM_AZURE
VITE_AZURE_AUTHORITY=https://login.microsoftonline.com/common
VITE_AZURE_REDIRECT_URI=http://localhost:5173
VITE_AZURE_FILES_READ_ALL=false

# Bundled local price list (no Azure required)
VITE_PRICE_LIST_PATH=/data/accessories-price-list.xlsx
